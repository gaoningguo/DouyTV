{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop",
  "description": "Desktop-only capability for updater and process plugins",
  "windows": ["main"],
  "platforms": ["windows", "macos", "linux"],
  "permissions": [
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-exit",
    "process:allow-relaunch"
  ]
}
