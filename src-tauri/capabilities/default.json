{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main", "lyric"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:image:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$AUDIO/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    },
    "sql:default",
    {
      "identifier": "updater:default",
      "allow": ["check", "download", "install", "downloadAndInstall"],
      "platforms": ["windows", "macOS", "linux"]
    },
    {
      "identifier": "process:default",
      "allow": ["relaunch", "exit"],
      "platforms": ["windows", "macOS", "linux"]
    }
  ]
}
